# Research outputs (regenerated by runs; not committed)
results/
checkpoints/
*.ckpt
*.pt
*.pth
wandb/

# Built deliverables (GitHub Actions builds the PDF into docs/; the root copy
# is transient). The docs/ site itself IS committed.
report.pdf

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Raw Claude chat exports — kept LOCAL, never published. They embed a private
# "Recents" sidebar of unrelated conversations and ~10MB of web chrome each.
# Publishable, distilled context lives in data_lake/transcripts/ + diagrams/
# (committed), produced by data_lake/extract_chat_context.py.
data_lake/*.html
data_lake/*_files/
# Derived raster renders of the dark-theme SVGs (regenerable; render as black boxes)
data_lake/diagrams/*.png

# Session-local cron/scheduler state (transient, machine-specific)
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# IDE / OS / env
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
.env
.env.local
artifacts/

# Electron app deps (downloaded by npm install)
app/electron/node_modules/

# Experiment-intermediate crosspass figures (tagged --tag w19/w20/w21/...): auto-generated
# per-config ablation plots, regenerable from results/ JSONs. Curated/committed figures are
# untagged (docs/crosspass.png, docs/crosspass_gpt2-medium.png, ...) and stay tracked.
docs/crosspass_*_w[0-9]*.png
/reference images

# Saved external-review chat exports (web-export asset dirs are huge; the
# distilled digest lives in data_lake/external_reviews_*.md)
chats/
