# Research outputs (regenerated by runs; not committed)
results/
checkpoints/
*.ckpt
*.pt
*.pth
wandb/

# Built deliverables (GitHub Actions builds the PDF into docs/; the root copy
# is transient). The docs/ site itself IS committed.
report.pdf

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Raw Claude chat exports — kept LOCAL, never published. They embed a private
# "Recents" sidebar of unrelated conversations and ~10MB of web chrome each.
# Publishable, distilled context lives in data_lake/transcripts/ + diagrams/
# (committed), produced by data_lake/extract_chat_context.py.
data_lake/*.html
data_lake/*_files/
# Derived raster renders of the dark-theme SVGs (regenerable; render as black boxes)
data_lake/diagrams/*.png

# Session-local cron/scheduler state (transient, machine-specific)
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# IDE / OS / env
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
.env
.env.local
